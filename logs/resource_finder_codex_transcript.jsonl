{"type":"item.started","item":{"id":"item_60","type":"command_execution","command":"/bin/bash -lc \"pwd && source .venv/bin/activate && python - <<'PY'\nfrom pathlib import Path\nimport json\nimport requests\nimport pandas as pd\nfrom datasets import load_dataset, load_from_disk\n\nroot = Path('datasets')\nroot.mkdir(exist_ok=True)\n\n# 1) CLUTRR direct CSV download from the HF script's raw GitHub source.\nclutrr_task = 'gen_train234_test2to10'\nclutrr_dir = root / 'clutrr_v1_gen_train234_test2to10'\nclutrr_dir.mkdir(parents=True, exist_ok=True)\nbase = 'https://raw.githubusercontent.com/kliang5/CLUTRR_huggingface_dataset/main/' + clutrr_task\nclutrr_counts = {}\nclutrr_samples = {}\nfor split in ['train', 'validation', 'test']:\n    url = f'{base}/{split}.csv'\n    out = clutrr_dir / f'{split}.csv'\n    if not out.exists() or out.stat().st_size < 1000:\n        print('download', url)\n        r = requests.get(url, timeout=60)\n        r.raise_for_status()\n        out.write_bytes(r.content)\n    df = pd.read_csv(out)\n    clutrr_counts[split] = len(df)\n    clutrr_samples[split] = df.head(2).to_dict(orient='records')\n(clutrr_dir / 'samples').mkdir(exist_ok=True)\n(clutrr_dir / 'samples' / 'examples.json').write_text(json.dumps(clutrr_samples, indent=2)[:50000])\n\n# 2) bAbI JSONL dataset.\nbabi_dir = root / 'babi_muennighoff'\nif not babi_dir.exists():\n    babi = load_dataset('Muennighoff/babi')\n    babi.save_to_disk(str(babi_dir))\nelse:\n    babi = load_from_disk(str(babi_dir))\nbabi_counts = {k: len(v) for k, v in babi.items()}\n(babi_dir / 'samples').mkdir(exist_ok=True)\nbabi_sample = {k: [babi[k][i] for i in range(min(3, len(babi[k])))] for k in babi.keys()}\n(babi_dir / 'samples' / 'examples.json').write_text(json.dumps(babi_sample, indent=2)[:50000])\n\n# 3) MNIST for AddMNIST-style perception + symbolic arithmetic tasks.\nmnist_dir = root / 'mnist'\nif not mnist_dir.exists():\n    mnist = load_dataset('ylecun/mnist', 'mnist')\n    mnist.save_to_disk(str(mnist_dir))\nelse:\n    mnist = load_from_disk(str(mnist_dir))\nmnist_counts = {k: len(v) for k, v in mnist.items()}\n(mnist_dir / 'samples').mkdir(exist_ok=True)\n# Save labels and image dimensions only to keep the sample file tiny.\nmnist_sample = {}\nfor split in mnist.keys():\n    rows = []\n    for i in range(min(5, len(mnist[split]))):\n        item = mnist[split][i]\n        img = item['image']\n        rows.append({'label': item['label'], 'image_mode': img.mode, 'image_size': list(img.size)})\n    mnist_sample[split] = rows\n(mnist_dir / 'samples' / 'examples.json').write_text(json.dumps(mnist_sample, indent=2))\n\nprint('CLUTRR counts', clutrr_counts)\nprint('bAbI counts', babi_counts)\nprint('MNIST counts', mnist_counts)\nprint('done')\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
